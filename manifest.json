{
  "manifest_version": 3,
  "name": "GTA VICELAUNCHER - Cloud Play & Mod Launcher",
  "version": "1.2.0",
  "description": "Chrome Cloud Play Launcher & smartphone mod for GTA Vice City",
  "permissions": [
    "tabs",
    "scripting",
    "webNavigation",
    "downloads"
  ],
  "host_permissions": [
    "*://*.quenq.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.quenq.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}